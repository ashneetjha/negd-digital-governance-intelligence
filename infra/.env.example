# ──────────────────────────────────────────────────────────────────────────────
# NeGD Digital Governance Intelligence Portal v2.0.0
# Environment Variables Template
# Copy this file to .env in the project root and fill in all values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development          # development | production
DEBUG=true                   # accepts true/false and dev/release aliases
STRICT_REAL_AI=true          # true = fail fast if AI dependencies are unavailable

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000", "https://your-site.netlify.app"]

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-role-key

# ── LLM (Groq) ────────────────────────────────────────────────────────────────
LLM_PROVIDER=groq
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.1-8b-instant

# ── Embeddings ────────────────────────────────────────────────────────────────
# HuggingFace Inference API (RECOMMENDED for production — zero RAM overhead)
# Get a free read token at: https://huggingface.co/settings/tokens
# When set: embeddings are computed remotely (HF API), no local torch needed.
# When blank: falls back to local sentence-transformers (requires torch install).
HF_API_TOKEN=

EMBEDDING_MODEL=all-MiniLM-L6-v2    # 384-dim
EMBEDDING_DIMENSION=384

# ── RAG ───────────────────────────────────────────────────────────────────────
RAG_TOP_K=8
CHUNK_SIZE=600
CHUNK_OVERLAP=100

# ── Uploads ───────────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=50
UPLOAD_DIR=/tmp/negd_uploads

# ──────────────────────────────────────────────────────────────────────────────
# FRONTEND (.env.local in /frontend directory)
# ──────────────────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_API_URL=http://localhost:8000          # local dev
# NEXT_PUBLIC_API_URL=https://your-backend.onrender.com  # production
