# ──────────────────────────────────────────────────────────────────────────────
# NeGD Digital Governance Intelligence Portal — Environment Variables Template
# Copy this file to .env in the project root and fill in all values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development          # development | production
DEBUG=true                   # accepts true/false and dev/release aliases
STRICT_REAL_AI=true          # true = fail fast if AI dependencies are unavailable

# ── CORS ──────────────────────────────────────────────────────────────────────
# Frontend origin(s) allowed to call the backend.
# In production, set to your Vercel / Netlify URL.
ALLOWED_ORIGINS=["http://localhost:3000", "https://your-site.vercel.app"]

# ── Supabase ──────────────────────────────────────────────────────────────────
# From: https://app.supabase.com → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-or-service-role-key

# ── LLM (Groq) ───────────────────────────────────────────────────────────────
# From: https://console.groq.com/keys
LLM_PROVIDER=groq
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.1-8b-instant

# ── Embeddings ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2    # 384-dim, free, offline
EMBEDDING_DIMENSION=384

# ── RAG ───────────────────────────────────────────────────────────────────────
RAG_TOP_K=8                 # Number of chunks retrieved per query
CHUNK_SIZE=600              # Target characters per chunk
CHUNK_OVERLAP=100           # Overlap between consecutive chunks

# ── Uploads ───────────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=50
UPLOAD_DIR=/tmp/negd_uploads  # Temporary storage for uploaded files

# ──────────────────────────────────────────────────────────────────────────────
# FRONTEND (.env.local in /frontend directory)
# ──────────────────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_API_URL=http://localhost:8000     # local dev
# NEXT_PUBLIC_API_URL=https://your-backend.onrender.com  # production
